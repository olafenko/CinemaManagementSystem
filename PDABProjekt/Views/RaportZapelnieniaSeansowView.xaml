<local:RaportViewBase x:Class="PDABProjekt.Views.RaportZapelnieniaSeansowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDABProjekt.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White" Width="auto" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Raport zapełnienia seansów w wybranym dniu" HorizontalContentAlignment="Center" FontSize="14px" FontWeight="Medium"/>
        <Separator Grid.Row="1"/>
        <Grid Grid.Row="2" Width="600" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Label Content="Data " Grid.Column="0" Margin="3" HorizontalAlignment="Center" />
            <DatePicker Grid.Column="1" Margin="3" SelectedDate="{Binding Data}"/>
        </Grid>
        <Button Grid.Row="3" Content="Oblicz" Margin="3" Width="600"  Command="{Binding ObliczCommand}" HorizontalAlignment="Left"/>
       
        <DataGrid Grid.Row="4" ItemsSource="{Binding ElementyRaportu}" Width="auto" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Film" Binding="{Binding TytulSeansu}"/>
                <DataGridTextColumn Header="Od" Binding="{Binding GodzinaOd}"/>
                <DataGridTextColumn Header="Do" Binding="{Binding GodzinaDo}"/>
                <DataGridTextColumn Header="Liczba miejsc" Binding="{Binding LiczbaMiejsc}"/>
                <DataGridTextColumn Header="Zajete miejsca" Binding="{Binding LiczbaZajetychMiejsc}"/>
                <DataGridTextColumn Header="Wypełnienie %" Binding="{Binding ProcentWypelnienia, StringFormat={}{0:P2}}"/>
                <DataGridTextColumn Header="Status wypełnienia" Binding="{Binding StatusWypelnienia}"/>

            </DataGrid.Columns>
           

        </DataGrid>



    </Grid>
</local:RaportViewBase>
