<local:RaportViewBase x:Class="PDABProjekt.Views.StatystykiOgolneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDABProjekt.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White" Width="400" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="33"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Ogólne statystyki dzienne" HorizontalContentAlignment="Center" FontSize="14px" FontWeight="Medium"/>
        <Separator Grid.Row="1"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Od" Margin="3" HorizontalContentAlignment="Center"/>
            <DatePicker Grid.Column="1" Margin="3" SelectedDate="{Binding Data}"/>
        </Grid>
        <Button Grid.Row="3" Content="Oblicz" Margin="3" Command="{Binding ObliczCommand}"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Łączna ilość sprzedanych biletów:" Margin="3" HorizontalContentAlignment="Left"/>
            <Label Grid.Column="1" Content="{Binding SprzedaneBilety}" Margin="3" HorizontalContentAlignment="Left"/>
        </Grid>
        <Separator Grid.Row="5"/>
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label  Grid.Column="0" Content="Utarg wynosi: " Margin="3"/>
            <Label  Grid.Column="1" Margin="3" HorizontalContentAlignment="Left" Content="{Binding Utarg}" ContentStringFormat="C" Language="pl"/>
        </Grid>
        <Separator Grid.Row="7"/>
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label  Grid.Column="0" Content="Najpopularniejszy seans: " Margin="3"/>
            <Label  Grid.Column="1" Margin="3" HorizontalContentAlignment="Left" Content="{Binding NajpopularniejszySeans}"/>
        </Grid>
        <Separator Grid.Row="9"/>
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label  Grid.Column="0" Content="Najpopularniejszy film: " Margin="3"/>
            <Label  Grid.Column="1" Margin="3" HorizontalContentAlignment="Left" Content="{Binding NajpopularniejszyFilm}"/>
        </Grid>
        <Separator Grid.Row="11"/>
        <Grid Grid.Row="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label  Grid.Column="0" Content="Średnie wypełnienie sali: " Margin="3"/>
            <Label  Grid.Column="1" Margin="3" HorizontalContentAlignment="Left" Content="{Binding SrednieWypelnienieSali}" ContentStringFormat="P"/>
        </Grid>
        <Separator Grid.Row="13"/>
        <Grid Grid.Row="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label  Grid.Column="0" Content="Łączna liczba seansów: " Margin="3"/>
            <Label  Grid.Column="1" Margin="3" HorizontalContentAlignment="Left" Content="{Binding LiczbaSeansow}"/>
        </Grid>
        <Separator Grid.Row="15"/>
    </Grid>
</local:RaportViewBase>
