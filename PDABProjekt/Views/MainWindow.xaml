<Window x:Class="PDABProjekt.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  
        Title="PDABProjekt" Height="300" Width="300" WindowState="Maximized"
        xmlns:vm="clr-namespace:PDABProjekt.Views"
        >
    <Window.Resources>
        <ResourceDictionary Source="MainWindowResources.xaml"  />
    </Window.Resources>
    <Grid Background="#202123">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Menu Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="2" Background="#2A2B2E" Foreground="White">
            <MenuItem Header="_Plik"/>
            <MenuItem Header="_Moduły">
                <MenuItem Header="Zarządzaj filmami"/>
                <MenuItem Header="Zarządzaj seansami"/>
                <MenuItem Header="Zarządzaj salami"/>
                <MenuItem Header="Słowniki"/>
            </MenuItem>
            <MenuItem Header="Program"/>
        </Menu>
        <HeaderedContentControl Grid.Row="1" Grid.Column="0" Header="Operacje" Style="{StaticResource MainHCCStyle}">
            <ScrollViewer  Background="#2A2B2E" Margin="5,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Expander Header="Główne operacje" FontSize="18" FontWeight="DemiBold" BorderThickness="1"  Foreground="White" BorderBrush="#4A90E2" Margin="5,5,5,5" Padding="5,0,0,0">
                        <ItemsControl ItemsSource="{Binding GlowneCommands}" ItemTemplate="{StaticResource CommandsTemplate}"/>
                    </Expander>
                    <Separator Margin="0,3,0,3"/>
                    <Expander Header="Słowniki" FontSize="18" FontWeight="DemiBold" BorderThickness="1" Background="#2A2B2E" Foreground="White" BorderBrush="#4A90E2" Margin="5,5,5,5" Padding="5,0,0,0">
                        <ItemsControl ItemsSource="{Binding SlownikoweCommands}" ItemTemplate="{StaticResource CommandsTemplate}"/>
                    </Expander>
                    <Separator Margin="0,3,0,3"/>
                    <Expander Header="Raporty" FontSize="18" FontWeight="DemiBold" BorderThickness="1" Background="#2A2B2E" Foreground="White" BorderBrush="#4A90E2" Margin="5,5,5,5" Padding="5,0,0,0">
                        <ItemsControl ItemsSource="{Binding RaportyCommands}" ItemTemplate="{StaticResource CommandsTemplate}"/>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </HeaderedContentControl>


        <Border Grid.Row="1" Grid.Column="1" >
            <HeaderedContentControl 
                Header="Przestrzeń robocza"
                Content="{Binding Path=Workspaces}"
                ContentTemplate="{StaticResource WorkspacesTemplate}"
                Style="{StaticResource MainHCCStyle}"
            />
        </Border>
        <StatusBar Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Background="#202123" Foreground="WhiteSmoke">
            <StatusBarItem Margin="5,0,0,0">
                <TextBlock >Autor</TextBlock>
            </StatusBarItem>
            <Separator/>
            <TextBlock>Olaf Chechelski</TextBlock>
        </StatusBar>
    </Grid>
</Window>
