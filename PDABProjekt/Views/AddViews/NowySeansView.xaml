<local:JedenViewBase
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDABProjekt.Views"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf" x:Class="PDABProjekt.Views.NowySeansView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="10" Background="#202123">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="200"/>

            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0" Content="Film: " Margin="0,10" FontWeight="Bold" Foreground="#f0f0f0"/>
            <TextBox IsEnabled="False" Grid.Column="1" Grid.Row="0" Margin="0,10" FontWeight="Bold" Text="{Binding Path=TytulFilmu, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="..." Grid.Column="2" Grid.Row="0" Margin="0,10" Command="{Binding ShowFilmy}"/>

            <Label Grid.Column="0" Grid.Row="1" Content="Gatunek filmu: " Margin="0,10" FontWeight="Bold" Foreground="#f0f0f0"/>
            <TextBox IsEnabled="False" Grid.Column="1" Grid.Row="1" Margin="0,10" FontWeight="Bold" Text="{Binding Path=GatunekFilmu, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Grid.Column="0" Grid.Row="2" Content="Czas trwania filmu: " Margin="0,10" FontWeight="Bold" Foreground="#f0f0f0"/>
            <TextBox IsEnabled="False" Grid.Column="1" Grid.Row="2" Margin="0,10" FontWeight="Bold" Text="{Binding Path=CzasTrwaniaFilmu, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Grid.Column="0" Grid.Row="3" Content="Sala: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox IsEnabled="False" Grid.Column="1" Grid.Row="3" Margin="0,10" FontWeight="Bold" Text="{Binding Path=NumerSali, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="..." Grid.Column="2" Grid.Row="3" Margin="0,10" Command="{Binding ShowSale}"/>

            <Label Grid.Column="0" Grid.Row="4" Content="Typ sali: " Margin="0,10" FontWeight="Bold" Foreground="#f0f0f0"/>
            <TextBox IsEnabled="False" Grid.Column="1" Grid.Row="4" Margin="0,10" FontWeight="Bold" Text="{Binding Path=TypSali, UpdateSourceTrigger=PropertyChanged}"/>

            <Label  Grid.Column="0" Grid.Row="5" Content="Status seansu: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="5" Margin="0,10" Foreground="Black"
                ItemsSource="{Binding StatusySeansuItems}"
                DisplayMemberPath="Nazwa"
                SelectedValuePath="IdStatusuSeansu"
                SelectedValue="{Binding IdStatusuSeansu, Mode=TwoWay}"/>

            <Label  Grid.Column="0" Grid.Row="6" Content="Język: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="6" Margin="0,10" Foreground="Black"
        ItemsSource="{Binding JezykiItems}"
        DisplayMemberPath="Nazwa"
        SelectedValuePath="IdJezyka"
        SelectedValue="{Binding IdJezyka, Mode=TwoWay}"/>

            <Rectangle Grid.Column="3" Grid.RowSpan="8" VerticalAlignment="Stretch" Width="0.5" Fill="White"/>

            <Label Grid.Column="4" Grid.Row="0" Content="Data seansu: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <DatePicker Grid.Column="5" Grid.Row="0" Margin="0,10" Foreground="Black" SelectedDate="{Binding DataSeansu}"/>

            <Label  Grid.Column="4" Grid.Row="1" Content="Godzina od: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <syncfusion:SfTimePicker AllowNull="False" Grid.Column="5" Grid.Row="1" Width="120" HorizontalAlignment="Left" Value="{Binding GodzinaOdUi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Label  Grid.Column="4" Grid.Row="2" Content="Godzina do: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <syncfusion:SfTimePicker IsEnabled="False" AllowNull="False" Grid.Column="5" Grid.Row="2" Width="120" HorizontalAlignment="Left" Value="{Binding GodzinaDoUi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
           

            <Label Grid.Column="4" Grid.Row="3" Content="Napisy " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <CheckBox Grid.Column="5" Grid.Row="3" Margin="0,10" Foreground="Black" IsChecked="{Binding CzyNapisy, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

            <Label Grid.Column="4" Grid.Row="4" Content="Dubbing " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <CheckBox Grid.Column="5" Grid.Row="4" Margin="0,10" Foreground="Black" IsChecked="{Binding CzyDubbing, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

            <Label Grid.Column="4" Grid.Row="5" Content="Lektor " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <CheckBox Grid.Column="5" Grid.Row="5" Margin="0,10" Foreground="Black" IsChecked="{Binding CzyLektor, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

           
        </Grid>
    </Border>
</local:JedenViewBase>
