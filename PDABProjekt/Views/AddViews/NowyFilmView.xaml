<local:JedenViewBase x:Class="PDABProjekt.Views.NowyFilmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDABProjekt.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="10" Background="#202123">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Column="0" Grid.Row="0" Content="Tytuł: " Margin="0,10" FontWeight="Bold" Foreground="#f0f0f0"/>
            <TextBox Grid.Column="1" Grid.Row="0" Margin="0,10" Foreground="Black" Text="{Binding Path=Tytul, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Grid.Column="0" Grid.Row="1" Content="Tytuł oryginalny: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox Grid.Column="1" Grid.Row="1" Margin="0,10" Foreground="Black" Text="{Binding Path=TytulOryginalny, UpdateSourceTrigger=PropertyChanged}"/>

            <Label  Grid.Column="0" Grid.Row="2" Content="Gatunek: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="2" Margin="0,10" Foreground="Black"
                    ItemsSource="{Binding GatunkiFilmuItems}"
                    DisplayMemberPath="NazwaGatunku"
                    SelectedValuePath="IdGatunku"
                    SelectedValue="{Binding Path=IdGatunku, Mode=TwoWay}"/>   

            <Label  Grid.Column="0" Grid.Row="3" Content="Kategoria wiekowa: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="3" Margin="0,10" Foreground="Black"
            ItemsSource="{Binding KategorieWiekoweItems}"
            DisplayMemberPath="NazwaKategorii"
            SelectedValuePath="IdKategoriiWiekowej"
            SelectedValue="{Binding Path=IdKategoriiWiekowej, Mode=TwoWay}"/>

            <Label Grid.Column="0" Grid.Row="4" Content="Czas trwania (min): " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox Grid.Column="1" Grid.Row="4" Margin="0,10" Foreground="Black" Text="{Binding Path=CzasTrwania, UpdateSourceTrigger=PropertyChanged}"/>

            <Label  Grid.Column="0" Grid.Row="5" Content="Jezyk oryginalny audio: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="5" Margin="0,10" Foreground="Black"
             ItemsSource="{Binding JezykiItems}"
             DisplayMemberPath="Nazwa"
             SelectedValuePath="IdJezyka"
             SelectedValue="{Binding Path=IdJezykaOryginalnego, Mode=TwoWay}"/>

            <Label Grid.Column="0" Grid.Row="6" Content="Dystrybutor: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox IsEnabled="False" Grid.Column="1" Grid.Row="6" Margin="0,10" FontWeight="Bold" Text="{Binding Path=NazwaDystrybutora, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="..." Grid.Column="2" Grid.Row="6" Margin="0,10" Command="{Binding ShowDystrybutorzy}"/>

            <Rectangle Grid.Column="3" Grid.RowSpan="8" VerticalAlignment="Stretch" Width="0.5" Fill="White"/>

            <Label Grid.Column="4" Grid.Row="0" Content="Data premiery: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <DatePicker Grid.Column="5" Grid.Row="0" Margin="0,10" Foreground="Black" SelectedDate="{Binding DataPremiery}"/>

            <Label Grid.Column="4" Grid.Row="1" Content="Rok produkcji: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox Grid.Column="5" Grid.Row="1" Margin="0,10" Foreground="Black" Text="{Binding Path=RokProdukcji, UpdateSourceTrigger=PropertyChanged}"/>

            <Label  Grid.Column="4" Grid.Row="2" Content="Kraj produkcji:" Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="5" Grid.Row="2" Margin="0,10" Foreground="Black"
             ItemsSource="{Binding KrajeProdukcjiItems}"
             DisplayMemberPath="Nazwa"
             SelectedValuePath="IdKraju"
             SelectedValue="{Binding Path=IdKraju, Mode=TwoWay}"/>

            <Label  Grid.Column="4" Grid.Row="3" Content="Producent: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="5" Grid.Row="3" Margin="0,10" Foreground="Black"
             ItemsSource="{Binding ProducenciItems}"
             DisplayMemberPath="Nazwa"
             SelectedValuePath="IdProducenta"
             SelectedValue="{Binding Path=IdProducenta, Mode=TwoWay}"/>

            <Label  Grid.Column="4" Grid.Row="4" Content="Reżyser: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="5" Grid.Row="4" Margin="0,10" Foreground="Black"
             ItemsSource="{Binding RezyserzyItems}"
             DisplayMemberPath="Nazwisko"
             SelectedValuePath="IdRezysera"
             SelectedValue="{Binding Path=IdRezysera, Mode=TwoWay}"/>

            <Label  Grid.Column="4" Grid.Row="5" Content="Status: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="5" Grid.Row="5" Margin="0,10" Foreground="Black"
             ItemsSource="{Binding StatusyFilmuItems}"
             DisplayMemberPath="NazwaStatusu"
             SelectedValuePath="IdStatusuFilmu"
             SelectedValue="{Binding Path=IdStatusu, Mode=TwoWay}"/>

            <Label Grid.Column="4" Grid.Row="6" Content="Url plakatu: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox Grid.Column="5" Grid.Row="6" Margin="0,10" Foreground="Black" Text="{Binding Path=UrlPlakatu, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Grid.Column="4" Grid.Row="7" Content="Opis: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox Grid.Column="5" Grid.Row="7" Margin="0,10" Foreground="Black" TextWrapping="Wrap" Text="{Binding Path=Opis, UpdateSourceTrigger=PropertyChanged}"/>

    </Grid>
    </Border>
</local:JedenViewBase>
