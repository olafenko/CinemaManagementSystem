<local:JedenViewBase x:Class="PDABProjekt.Views.AddHallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDABProjekt.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="10" Background="#202123">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0" Content="Numer sali: " Margin="0,10" FontWeight="Bold" Foreground="#f0f0f0"/>
            <TextBox Grid.Column="1" Grid.Row="0" Margin="0,10" Foreground="Black" Text="{Binding Path=HallNumber, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Grid.Column="0" Grid.Row="1" Content="Liczba miejsc: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <TextBox Grid.Column="1" Grid.Row="1" Margin="0,10" Foreground="Black" Text="{Binding Path=SeatsCount, UpdateSourceTrigger=PropertyChanged}"/>

            <Label  Grid.Column="0" Grid.Row="2" Content="Typ ekranu: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="2" Margin="0,10" Foreground="Black"
                ItemsSource="{Binding ScreenTypes}"
                DisplayMemberPath="Nazwa"
                SelectedValuePath="IdTypuEkranu"
                SelectedValue="{Binding Path=ScreenTypeId, Mode=TwoWay}"/>

            <Label  Grid.Column="0" Grid.Row="3" Content="Typ nagłośnienia: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="3" Margin="0,10" Foreground="Black"
        ItemsSource="{Binding SoundSystemTypes}"
        DisplayMemberPath="Nazwa"
        SelectedValuePath="IdTypuNaglosnienia"
        SelectedValue="{Binding Path=SoundSystemTypeId, Mode=TwoWay}"/>

            <Label  Grid.Column="0" Grid.Row="4" Content="Typ sali: " Margin="0,10" FontWeight="Bold" Foreground="White"/>
            <ComboBox  Grid.Column="1" Grid.Row="4" Margin="0,10" Foreground="Black"
                    ItemsSource="{Binding HallTypes}"
                    DisplayMemberPath="Nazwa"
                    SelectedValuePath="IdTypuSali"
                    SelectedValue="{Binding Path=HallTypeId, Mode=TwoWay}"/>
        

        </Grid>
    </Border>
</local:JedenViewBase>
