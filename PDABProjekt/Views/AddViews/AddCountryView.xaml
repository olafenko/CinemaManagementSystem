<local:JedenViewBase x:Class="PDABProjekt.Views.AddCountryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDABProjekt.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Padding="10" Background="#202123">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0" Content="Nazwa"  FontWeight="Bold" Foreground="White" VerticalAlignment="Bottom"/>
            <TextBox Grid.Column="0" Grid.Row="1" Height="20" Margin="0,10" Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged}"/>

        </Grid>
    </Border>
    
</local:JedenViewBase>
